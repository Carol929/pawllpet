    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "jsdom": "^29.0.2",
    "prisma": "^5.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
