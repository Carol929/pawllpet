    "bcryptjs": "^2.4.3",
    "jose": "^5.2.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.0.4",
    "next": "^14.2.0",
    "next-auth": "^5.0.0-beta.15",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^3.2.0",
    "stripe": "^20.4.1",
    "zod": "^3.22.4"
