// Prisma数据模型定义
// 用于生成数据库表结构和Prisma Client

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 用户表
model User {
  id            String    @id @default(cuid())
  fullName      String
  username      String    @unique // 用户名，唯一
  email         String    @unique // 邮箱，唯一
  emailVerified Boolean   @default(false) // 邮箱是否已验证
  password      String?   // 密码哈希（可选，Google登录用户可能没有）
  phone         String?   // 手机号（可选）
  petType       String?   // 宠物类型："Cat", "Dog", "Both", "Other"
  gender        String?   // 性别："Male", "Female", "Other", "Prefer not to say"
  birthday      DateTime? // 生日
  avatarUrl     String?   // 头像URL（预留）
  role          String    @default("user") // 用户角色："user" 或 "admin"
  isBlocked     Boolean   @default(false) // 是否被禁用
  createdAt     DateTime  @default(now()) // 创建时间
  updatedAt     DateTime  @updatedAt // 更新时间
  lastLoginAt   DateTime? // 最后登录时间

  // NextAuth.js 关联表
  accounts      Account[] // OAuth账号（Google等）
  sessions      Session[] // 用户会话

  // 邮箱验证Token
  emailVerificationToken EmailVerificationToken?

  // 关联
  products  Product[]  // 管理员创建的产品
  addresses Address[]  // 收货地址
  orders    Order[]    // 订单
  wishlists Wishlist[] // 收藏
  reviews   Review[]   // 评价
  pets      Pet[]      // 宠物档案

  @@map("users")
}

// 产品分类表
model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[] @relation("PrimaryCategory")
  taggedProducts Product[] @relation("ProductCategories")

  @@map("categories")
}

// 产品表
model Product {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  subtitle       String?
  description    String   @db.Text
  categoryId     String
  petType        String   @default("Both") // "Dog", "Cat", "Both"
  brand          String?
  material       String?
  price          Float    @default(0)
  compareAtPrice Float?
  weight         Float?   // Weight in lbs, used for shipping calculation
  stock          Int      @default(0)
  rating         Float    @default(0)
  status         String   @default("draft") // "draft", "live", "archived"
  isNew          Boolean  @default(false)
  isBestSeller   Boolean  @default(false)
  isDrop         Boolean  @default(false)
  isBundle       Boolean  @default(false)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category   Category         @relation("PrimaryCategory", fields: [categoryId], references: [id])
  categories Category[]       @relation("ProductCategories")
  createdBy  User?            @relation(fields: [createdById], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  wishlists  Wishlist[]
  reviews    Review[]

  @@index([status])
  @@index([status, createdAt])
  @@index([categoryId])
  @@index([isNew])
  @@index([isBestSeller])
  @@map("products")
}

// 产品图片表
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// 产品变体表 (如不同类型/尺寸)
model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String
  sku       String?  @unique
  price     Float
  stock      Int      @default(0)
  imageIndex Int?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

// 收货地址表
model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   @default("Home")
  fullName  String
  phone     String?
  street    String
  city      String
  state     String
  zip       String
  country   String   @default("US")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("addresses")
}

// 订单表
model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          String      @default("pending")
  total           Float
  subtotal        Float
  shipping        Float       @default(0)
  tax             Float       @default(0)
  discountAmount  Float       @default(0)
  discountCode    String?
  shippingAddress Json
  stripeSessionId String?     @unique
  trackingNumber  String?
  cancellationReason       String?
  cancellationRequestedAt  DateTime?
  cancelledAt              DateTime?
  deliveredAt              DateTime?
  resolution               String?
  refundAmount             Float?
  adminNote                String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}

// 订单商品表
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  variantId String? // ProductVariant ID — null for base product purchases
  name      String
  image     String
  price     Float
  quantity  Int

  @@index([orderId])
  @@map("order_items")
}

// NextAuth.js - OAuth账号表
// 用于存储Google等第三方登录账号信息
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String // 账号类型，如 "oauth"
  provider          String // 提供商，如 "google"
  providerAccountId String // 提供商账号ID
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// NextAuth.js - 会话表
// 用于存储用户登录会话
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// NextAuth.js - 验证Token表
// 用于NextAuth.js内部的验证流程
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// 邮箱验证Token表
// 用于存储邮箱验证token
model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique // 验证token（唯一）
  userId    String   @unique // 关联的用户ID（唯一，一个用户一个未验证的token）
  expires   DateTime // token过期时间
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) // 创建时间

  @@map("email_verification_tokens")
}

// 宠物档案表
model Pet {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      String   // "Dog" | "Cat"
  breed     String?
  age       String?  // "Puppy/Kitten", "Young", "Adult", "Senior"
  weight    String?  // "Small", "Medium", "Large"
  allergies String?
  photoUrl  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("pets")
}

// 收藏表
model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

// 评价表
model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  title     String?
  body      String?  @db.Text
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@map("reviews")
}
