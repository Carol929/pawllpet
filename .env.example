# Payments
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Shipping
# SHIPPING_PROVIDER selects the strategy at runtime:
#   "legacy" — use the hardcoded weight-tier table in lib/shipping-rates.ts (current production default)
#   "shippo" — use Shippo Rates API + auto-buy labels on payment
# On error, the provider falls back to legacy so checkout never breaks.
SHIPPING_PROVIDER="legacy"
SHIPPO_API_KEY=""                       # shippo_test_xxx for dev/preview, prod key for production

# Origin address — pick ONE of the two approaches below:
#
# Approach A (recommended): reference an address stored in your Shippo
# account. Single source of truth — you manage the address in Shippo's
# dashboard and only one env var here. Get the object_id by running:
#   npx tsx scripts/shippo-list-addresses.ts <your_api_key>
SHIPPO_FROM_ADDRESS_ID=""               # e.g. "adr_xxxxxxxxxxxxxxxxxxxxxxxx"
#
# Approach B (fallback): build the address inline from these env vars.
# Used only if SHIPPO_FROM_ADDRESS_ID is empty. Leave commented if using A.
# SHIPPO_ORIGIN_NAME="PawLL Pet"
# SHIPPO_ORIGIN_STREET=""
# SHIPPO_ORIGIN_CITY="Arlington"
# SHIPPO_ORIGIN_STATE="VA"
# SHIPPO_ORIGIN_ZIP="22202"
# SHIPPO_ORIGIN_PHONE=""
# SHIPPO_ORIGIN_EMAIL="ops@pawllpet.com"
